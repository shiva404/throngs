# LLM Provider: "openai" or "google"
SWARM_LLM_PROVIDER=openai

# OpenAI
SWARM_OPENAI_API_KEY=sk-...
SWARM_OPENAI_MODEL=gpt-4o

# Google Gemini (alternative)
# SWARM_GOOGLE_API_KEY=...
# SWARM_GOOGLE_MODEL=gemini-1.5-pro

# Concurrency
SWARM_MAX_CONCURRENT_AGENTS=10
SWARM_RATE_LIMIT_RPM=60

# Browser
SWARM_BROWSER_HEADLESS=true
SWARM_VIEWPORT_WIDTH=1280
SWARM_VIEWPORT_HEIGHT=720

# Storage
SWARM_CHROMADB_PERSIST_DIR=./chroma_data
SWARM_OUTPUT_DIR=./output
SWARM_SCREENSHOTS_DIR=./output/screenshots
SWARM_HEATMAPS_DIR=./output/heatmaps
SWARM_REPORTS_DIR=./output/reports
